generator client {
  provider   = "prisma-client"
  output     = "./generated"
}

datasource db {
  provider = "sqlite"
}

model User {
  id    Int     @id @default(autoincrement())
  subId String? @unique
  email String  @unique
  name  String?
  weddingParticipants WeddingParticipant[]
}


enum WeddingStatus {
  DRAFT
  PLANNING
  CONFIRMED
  COMPLETED
  CANCELLED
}
model Wedding {
  id    Int     @id @default(autoincrement())
  name  String
  date  DateTime
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
  
  guest_count Int @default(0)
  currency String @default("BRL")
  status WeddingStatus @default(DRAFT)

  isPlannerManaged  Boolean @default(false)

  weddingParticipants WeddingParticipant[]
} 


model WeddingParticipant {
  id        Int      @id @default(autoincrement())
  user      User     @relation(fields: [userId], references: [id])
  userId    Int

  wedding   Wedding  @relation(fields: [weddingId], references: [id])
  weddingId Int
  
  name      String
  email     String
  phone     String
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}
